# Production environment
# Copy to prod.tfvars and set db_password: cp prod.tfvars.example prod.tfvars
environment = "prod"
region      = "us-east-2"  # TODO: set your region

# Database (larger for prod)
db_instance_class    = "db.t3.small"
db_allocated_storage = 50
db_password          = "CHANGE_ME_prod_password"

# ECS (more resources for prod)
ecs_cpu    = 512
ecs_memory = 1024
core_api_bootstrap_image_tag = "bootstrap"

# Domain (optional)
# domain_name         = "myapp.com"
# acm_certificate_arn = "arn:aws:acm:us-east-2:ACCOUNT_ID:certificate/CERT_ID"
# route53_zone_id     = "Z0000000000000"
