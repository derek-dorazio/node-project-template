{
  "name": "<projectName>",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "clients/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",

    "build": "turbo run build",
    "build:service": "turbo run build --filter=@<projectName>/core-api --filter=@<projectName>/shared",
    "build:<projectName>": "turbo run build --filter=@<projectName>/<projectName>",

    "lint": "eslint --max-warnings 0",
    "typecheck": "turbo run typecheck --force",
    "openapi-contract-check": "npm run api:export && npm run api:validate",

    "test:service:unit": "jest --config tests/jest.config.js tests/unit --forceExit",
    "test:service:integration": "jest --config tests/integration/jest.config.js --forceExit",
    "test:service:functional-api": "jest --config tests/functional/jest.config.js --forceExit",
    "test:service:functional-api:coverage": "jest --config tests/functional/jest.config.js --forceExit --coverage",
    "test:coverage:service:unit": "jest --config tests/jest.config.js --coverage --forceExit",
    "test:coverage:service:integration": "jest --config tests/integration/jest.config.js --coverage --forceExit",
    "test:coverage:service:merged": "node scripts/run-service-coverage.mjs",

    "test:<projectName>:unit": "cd clients/<projectName> && npx vitest run",

    "test:smoke:api": "jest --config tests/api/jest.config.ts --forceExit",
    "test:smoke:e2e": "cd clients/<projectName> && npx playwright test",
    "test:smoke": "npm run test:smoke:api && npm run test:smoke:e2e",

    "api:export": "cd packages/core-api && node -e \"require('./dist/index.js')\" --export-openapi",
    "api:generate": "cd packages/shared && npx @hey-api/openapi-ts",
    "api:validate": "node scripts/validate-openapi.mjs",
    "api:refresh": "npm run api:export && npm run api:generate && npm run api:validate",

    "db:migrate": "cd packages/core-api && npx prisma migrate dev",
    "db:seed": "cd packages/core-api && npx prisma db seed",
    "db:reset": "cd packages/core-api && npx prisma migrate reset",
    "db:studio": "cd packages/core-api && npx prisma studio"
  },
  "devDependencies": {
    "istanbul-lib-coverage": "^3.2.0",
    "istanbul-lib-report": "^3.0.0",
    "istanbul-reports": "^3.1.0",
    "v8-to-istanbul": "^9.3.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "eslint": "^9.0.0",
    "turbo": "^2.0.0",
    "@hey-api/openapi-ts": "^0.61.0",
    "prisma": "^6.0.0"
  }
}
