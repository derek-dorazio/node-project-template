{
  "name": "<projectName>",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "clients/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "eslint --max-warnings 0",
    "typecheck": "turbo run typecheck --force",
    "test": "jest --config tests/jest.config.js --forceExit",
    "test:unit": "jest --config tests/jest.config.js tests/unit --forceExit",
    "test:integration": "jest --config tests/integration/jest.config.js --forceExit",
    "test:functional": "jest --config tests/functional/jest.config.js --forceExit",
    "test:functional:coverage": "jest --config tests/functional/jest.config.js --forceExit --coverage",
    "test:coverage:unit": "jest --config tests/jest.config.js --coverage --forceExit",
    "test:coverage:integration": "jest --config tests/integration/jest.config.js --coverage --forceExit",
    "test:coverage:backend": "node scripts/run-backend-coverage.mjs",
    "test:smoke:api": "jest --config tests/api/jest.config.ts --forceExit",
    "test:smoke:e2e": "cd clients/<projectName> && npx playwright test",
    "test:smoke": "npm run test:smoke:api && npm run test:smoke:e2e",
    "api:export": "cd packages/core-api && node -e \"require('./dist/index.js')\" --export-openapi",
    "api:generate": "cd packages/shared && npx @hey-api/openapi-ts",
    "api:validate": "node scripts/validate-openapi.mjs",
    "api:refresh": "npm run api:export && npm run api:generate && npm run api:validate",
    "db:migrate": "cd packages/core-api && npx prisma migrate dev",
    "db:seed": "cd packages/core-api && npx prisma db seed",
    "db:reset": "cd packages/core-api && npx prisma migrate reset",
    "db:studio": "cd packages/core-api && npx prisma studio"
  }
}
